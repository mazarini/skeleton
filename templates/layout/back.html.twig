{% extends 'base.html.twig' %}

{% block title %}Admin
{% endblock %}

{%- block body_class -%}admin
{%- endblock -%}

{% block body %}
    <div
        class="d-flex" id="wrapper">

        <!-- Sidebar -->
        <div class="bg-light border-right" id="sidebar-wrapper">
            <div class="sidebar-heading">Start Bootstrap
            </div>
            {% include "back/_sidebar.html.twig" %}
        </div>
        <!-- /#sidebar-wrapper -->

        <!-- Page Content -->
        <div id="page-content-wrapper">

            {% include "back/_navbar.html.twig" %}

            <div class="container-fluid">
                {% block page %}{% endblock %}
            </div>
        </div>
        <!-- /#page-content-wrapper -->

    </div>
    <!-- /#wrapper -->
{% endblock %}
{% block javascripts %}
    <script>
        $("#menu-toggle").click(function (e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
        });
    </script>
{% endblock %}
