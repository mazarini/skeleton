{% extends 'base.html.twig' %}

{%- block body_class -%}
    front
{%- endblock -%}

{% block body %}
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            {% block navbar %}
                {% include "front/_navbar.html.twig" %}
            {% endblock %}
        </div>
    </nav>
    <!-- central -->
    <div class="container">

        <div
            class="row">

            <!-- Post Content Column -->
            <div class="col-md-8" id="pageId">
                {% block page %}{% endblock %}
            </div>
            <!-- Sidebar Widgets Column -->
            <div class="col-md-4" id="sidebar">
                {% block sidebar %}
                    {% include "front/_sidebar.html.twig" %}
                {% endblock %}
            </div>

        </div>
        <!-- /.row -->

    </div>
    <!-- /central -->

    <!-- Footer -->
    <footer class="py-3 bg-dark">
        {% block footer %}
            {% include "front/_footer.html.twig" %}
        {% endblock %}
    </footer>
{% endblock %}
