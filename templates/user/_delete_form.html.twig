<form method="post" action="{{ path('user_delete', {'id': user.id}) }}" id="user_delete" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input name="_method" type="hidden" value="DELETE">
    <input
    name="_token" type="hidden" value="{{ csrf_token('delete' ~ user.id) }}">
{# <button class="btn">Delete</button> #}
</form>
