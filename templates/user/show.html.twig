{% extends 'layout/back.html.twig' %}

{% block title %}User
{% endblock %}

{% block page %}
    <h1>User</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ user.id }}</td>
            </tr>
            <tr>
                <th>FullName</th>
                <td>{{ user.fullName }}</td>
            </tr>
            <tr>
                <th>Username</th>
                <td>{{ user.username }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ user.email }}</td>
            </tr>
            <tr>
                <th>Admin</th>
                <td>{{ user.admin ? 'Yes' : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn btn-outline-dark" href="{{ path('user_index') }}">back to list</a>

    <a class="btn btn-outline-dark" href="{{ path('user_edit', {'id': user.id}) }}">edit</a>

    <button class="btn btn-outline-dark" onclick="$('#modalId').modal('show')">Delete</button>

{% endblock %}

{% block modal %}
    {% embed 'tools/modal/_delete_form.html.twig' with { 'path': 'user_delete', 'id': user.id } only %}{% endembed %}
{% endblock %}
