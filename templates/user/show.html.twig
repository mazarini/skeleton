{% extends 'back.html.twig' %}

{% block title %}User
{% endblock %}

{% block page %}
    <h1>User</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ user.id }}</td>
            </tr>
            <tr>
                <th>FullName</th>
                <td>{{ user.fullName }}</td>
            </tr>
            <tr>
                <th>Username</th>
                <td>{{ user.username }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ user.email }}</td>
            </tr>
            <tr>
                <th>Admin</th>
                <td>{{ user.admin ? 'Yes' : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn btn-outline-dark" href="{{ path('user_index') }}">back to list</a>

    <a class="btn btn-outline-dark" href="{{ path('user_edit', {'id': user.id}) }}">edit</a>

    <button class="btn btn-outline-dark" onclick="$('#user_delete').submit()">Delete</button>

    {{ include('user/_delete_form.html.twig') }}
{% endblock %}
