{% extends 'design/layout.html.twig' %}

{% block title %}Asset
{% endblock %}

{% block body %}{% endblock %}

{% block modal_content %}
    Check that javascript is loaded and that jQuery is enabled; the "close" button should work.
{% endblock %}

{% block modal_footer_container %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        var element = document.getElementById('modalId');
        element.classList.add('show');
        element.style.display = "block";
    </script>
{% endblock %}
