{% extends 'design/layout.html.twig' %}

{% block title %}
    Layout|Header
{% endblock %}

{% block design_stylesheets %}
    {{ parent() }}
    <style>
        nav {
            min-height: 56px;
        }
        footer {
            min-height: 56px;
        }
    </style>
{% endblock %}

{% block navbar %}{% endblock %}
{% block sidebar %}{% endblock %}
{% block page %}{% endblock %}
{% block footer %}{% endblock %}

{% block design_modal %}
    {% embed 'design/_modal.html.twig' %}
        {% block message %}
            <p>This page contains only structure and content of header.</p>
        {% endblock %}
    {% endembed %}
{% endblock %}
